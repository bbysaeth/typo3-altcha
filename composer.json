{
    "name": "bbysaeth/typo3-altcha",
    "description": "TYPO3 form element for spam protection by utilizing the proof-of-work mechanism Altcha.",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "abuse",
        "altcha",
        "bot",
        "captcha",
        "proof-of-work",
        "recaptcha",
        "spam",
        "spam-protection",
        "typo3"
    ],
    "homepage": "https://github.com/bbysaeth/typo3-altcha",
    "type": "typo3-cms-extension",
    "autoload": {
        "psr-4": {
            "BBysaeth\\Typo3Altcha\\": "Classes/"
        }
    },
    "authors": [
        {
            "name": "Benjamin Bysäth",
            "email": "benjamin@bysaeth.de"
        }
    ],
    "require": {
        "typo3/cms-backend": "^13.4 || ^14.0",
        "typo3/cms-core": "^13.4 || ^14.0",
        "typo3/cms-extbase": "^13.4 || ^14.0",
        "typo3/cms-form": "^13.4 || ^14.0",
        "typo3/cms-fluid": "^13.4 || ^14.0",
        "altcha-org/altcha": "^2.0"
    },
    "suggest": {
        "typo3/cms-scheduler": "^13.4 || ^14.0"
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "altcha"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "require-dev": {
        "helmich/typo3-typoscript-lint": "^3.2",
        "phpstan/phpstan": "^2.1"
    }
}
